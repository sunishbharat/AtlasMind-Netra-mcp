# AtlasMind-Netra-mcp environment - copy to .env for local dev.
# Every NETRA_* variable is optional and overrides the default in config/settings.py.
# Nested settings use a double underscore: NETRA_<SECTION>__<FIELD>.

# --- Secrets (required, never defaulted, never committed) ---
# Groq API key, read by PydanticAI's Groq provider.
GROQ_API_KEY=gsk_your-key-here

# --- LLM (clarifier) ---
# Any PydanticAI model string works, e.g. groq:llama-3.3-70b-versatile, anthropic:claude-sonnet-4-6
#NETRA_LLM__MODEL=groq:llama-3.3-70b-versatile
#NETRA_LLM__TIMEOUT_SECONDS=30
#NETRA_LLM__RETRIES=2

# --- atlasMind-Lite backend (see docs/atlasmind_lite_api_contract.md) ---
#NETRA_LITE__BASE_URL=http://localhost:8000
#NETRA_LITE__QUERY_PATH=/query
#NETRA_LITE__TIMEOUT_SECONDS=60
#NETRA_LITE__MAX_RETRIES=3

# --- AtlasMind-frontendUI bridge (see docs/frontendui_bridge_contract.md) ---
#NETRA_FRONTEND__BASE_URL=http://localhost:8001
#NETRA_FRONTEND__INJECT_PATH=/api/mcp/inject
#NETRA_FRONTEND__TIMEOUT_SECONDS=10
# Bridge API key, forwarded as X-API-Key; leave unset when the bridge has no API_KEY
#NETRA_FRONTEND__API_KEY=

# --- Sessions (Phase 1 in-memory store) ---
#NETRA_SESSION__TTL_SECONDS=1800

# --- Clarification ---
#NETRA_CLARIFICATION__VOCAB_PATH=config/clarification_vocab.json
#NETRA_CLARIFICATION__PROMPT_PATH=prompts/clarification_prompt.md
#NETRA_CLARIFICATION__CONVENTIONS_PATH=data/conventions.json
#NETRA_CLARIFICATION__MAX_ROUNDS=3
# Paths into the atlasMind-Lite data directory (co-located deployment); unset = degrade gracefully
#NETRA_CLARIFICATION__JIRA_FIELDS_PATH=../AtlasMind/data/default/jira_fields.json
#NETRA_CLARIFICATION__ALLOWED_VALUES_PATH=../AtlasMind/data/default/jira_allowed_values.json

# --- Report delivery (human-verifiable markdown report per query) ---
#NETRA_DELIVERY__ENABLED=true
#NETRA_DELIVERY__CHANNEL=markdown_file
#NETRA_DELIVERY__OUTPUT_DIR=data/reports
#NETRA_DELIVERY__MAX_ISSUES=50

# --- MCP server ---
# stdio (dev, default) or streamable-http (production)
#NETRA_SERVER__TRANSPORT=stdio
#NETRA_SERVER__HOST=127.0.0.1
#NETRA_SERVER__PORT=8765

# --- Logging ---
#NETRA_LOG__LEVEL=INFO
#NETRA_LOG__JSON_LOGS=false
# Log file path (JSON lines, always written regardless of JSON_LOGS); set to empty to disable.
#NETRA_LOG__LOG_FILE=data/logs/netra.log
