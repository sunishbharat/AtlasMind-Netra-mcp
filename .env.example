# AtlasMind-Netra-mcp environment - copy to .env for local dev.
# Every NETRA_* variable is optional and overrides the default in config/settings.py.
# Nested settings use a double underscore: NETRA_<SECTION>__<FIELD>.

# =============================================================================
# LLM PROVIDER  -  uncomment exactly ONE block; leave all others commented out
# =============================================================================

# -- [1] GROQ (default out of the box) ---------------------------------------
#    Model  : groq:llama-3.3-70b-versatile
#    Key    : https://console.groq.com -> API Keys
#    Notes  : fast & cheap for short clarification calls; default when no
#             NETRA_LLM__MODEL is set
GROQ_API_KEY=gsk_your-key-here
#NETRA_LLM__MODEL=groq:llama-3.3-70b-versatile

# -- [2] ANTHROPIC ------------------------------------------------------------
#    Model  : anthropic:claude-sonnet-4-6
#    Key    : https://console.anthropic.com -> API Keys
#    Notes  : set NETRA_ANALYSIS__MAX_CONCURRENCY=1 on Anthropic Tier-1
#             to stay within burst limits
#ANTHROPIC_API_KEY=sk-ant-your-key-here
#NETRA_LLM__MODEL=anthropic:claude-sonnet-4-6

# -- [3] AWS BEDROCK ----------------------------------------------------------
#    Model  : bedrock:anthropic.claude-sonnet-4-5  (or any Bedrock model ID)
#    Notes  : uncomment credentials using ONE of the three methods below;
#             region defaults to AWS_DEFAULT_REGION; NETRA_LLM__BASE_URL is
#             optional (only needed for a custom/regional endpoint)
#
#    a) Bearer token - same approach as the aMind-partial backend
#AWS_BEARER_TOKEN_BEDROCK=your-bearer-token-here
#
#    b) Standard AWS key pair
#AWS_ACCESS_KEY_ID=AKIA...
#AWS_SECRET_ACCESS_KEY=your-secret-here
#AWS_DEFAULT_REGION=us-east-1
#
#    c) IAM role / instance profile - boto3 discovers automatically, no vars needed
#
#NETRA_LLM__MODEL=bedrock:anthropic.claude-sonnet-4-5
#NETRA_LLM__BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com

# -- [4] OPENAI-COMPATIBLE (Minimax via NVIDIA NIM, vLLM, LiteLLM, etc.) -----
#    Model  : openai:<model-id>  (prefix is always 'openai:')
#    Key    : NETRA_LLM__API_KEY  (forwarded as the Bearer token to the endpoint)
#    Notes  : NETRA_LLM__BASE_URL must point to your compatible endpoint;
#             OPENAI_API_KEY is also accepted if NETRA_LLM__API_KEY is unset
#
#    Example - Minimax M2.7 via NVIDIA NIM:
#NETRA_LLM__MODEL=openai:minimaxai/minimax-m2.7
#NETRA_LLM__BASE_URL=https://integrate.api.nvidia.com/v1
#NETRA_LLM__API_KEY=nvapi-your-key-here

# -- Shared LLM tuning (applies to all providers above) ----------------------
#NETRA_LLM__RETRIES=2

# =============================================================================
# BACKEND  -  atlasMind-Lite  (see docs/atlasmind_lite_api_contract.md)
# =============================================================================
#NETRA_LITE__BASE_URL=http://localhost:8000
#NETRA_LITE__QUERY_PATH=/query
#NETRA_LITE__TIMEOUT_SECONDS=300
#NETRA_LITE__MAX_RETRIES=3

# =============================================================================
# FRONTEND BRIDGE  -  AtlasMind-frontendUI  (see docs/frontendui_bridge_contract.md)
# =============================================================================
#NETRA_FRONTEND__BASE_URL=http://localhost:8001
#NETRA_FRONTEND__INJECT_PATH=/api/mcp/inject
#NETRA_FRONTEND__TIMEOUT_SECONDS=10
# Forwarded as X-API-Key; leave unset when the bridge has no API_KEY configured
#NETRA_FRONTEND__API_KEY=

# =============================================================================
# SESSIONS
# =============================================================================
#NETRA_SESSION__TTL_SECONDS=1800

# =============================================================================
# CLARIFICATION ENGINE
# =============================================================================
#NETRA_CLARIFICATION__VOCAB_PATH=config/clarification_vocab.json
#NETRA_CLARIFICATION__PROMPT_PATH=prompts/clarification_prompt.md
#NETRA_CLARIFICATION__CONVENTIONS_PATH=data/conventions.json
#NETRA_CLARIFICATION__MAX_ROUNDS=3
# Paths into the atlasMind-Lite data directory (co-located deployment); unset = degrade gracefully

# Jira instance with native dict-keyed fields format (e.g. issues.apache.org):
#NETRA_CLARIFICATION__JIRA_FIELDS_PATH=../jira_fields.json
#NETRA_CLARIFICATION__ALLOWED_VALUES_PATH=../jira_allowed_values.json

# =============================================================================
# ANALYSIS  -  IssueAnalyser concurrency
# =============================================================================
# Lower value = fewer concurrent LLM calls; raise for paid/higher-rate-limit accounts
#NETRA_ANALYSIS__MAX_CONCURRENCY=2

# =============================================================================
# DELIVERY  -  markdown report written per query / briefing
# =============================================================================
#NETRA_DELIVERY__ENABLED=true
#NETRA_DELIVERY__CHANNEL=markdown_file
#NETRA_DELIVERY__OUTPUT_DIR=data/reports
#NETRA_DELIVERY__MAX_ISSUES=50

# =============================================================================
# MCP SERVER
# =============================================================================
# stdio (dev, default) or streamable-http (production)
#NETRA_SERVER__TRANSPORT=stdio
#NETRA_SERVER__HOST=127.0.0.1
#NETRA_SERVER__PORT=8765

# =============================================================================
# LOGGING
# =============================================================================
#NETRA_LOG__LEVEL=INFO
#NETRA_LOG__JSON_LOGS=false
# JSON lines log file; set to empty string to disable (e.g. on ephemeral filesystems)
#NETRA_LOG__LOG_FILE=data/logs/netra.log
