# Markdown - ignore all, keep only README and tracked runtime assets
docs/
*.md
!README.md
!prompts/*.md
!confluence/prompts/*.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
htmlcov/

# Ignore all dotfiles and dot-directories by default
.*
!.gitignore
!.env.example
!.github/
!.dockerignore
!CONTRIBUTING.md

# Runtime data (learned conventions, caches, session-sharded convention files)
data/
data/conventions/

# CF static-file server directory (generated locally; not committed)
netra-fields-server/
